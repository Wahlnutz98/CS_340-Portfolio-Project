<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Product Suppliers</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <h1>Product Suppliers</h1>

    <form action="/restore-database" method="POST">
        <a href="index.html">Back to Home</a>
        <button type="submit">Reset database</button>
    </form>


    <h2>Browse Product Suppliers</h2>
    <!-- views/productSuppliers.ejs -->
    <table border="1">
        <thead>
            <tr>
                <th>Product Supplier ID</th>
                <th>Product ID</th>
                <th>Product Name</th>
                <th>Supplier ID</th>
                <th>Supplier Name</th>
                <th>Cost ($)</th>
            </tr>
        </thead>
        <tbody> <!--dynamically load the data in table using ejs template-->
            <% ProductSuppliers.forEach(function(productSupplier) { %>
                <tr>
                    <td><%= productSupplier.productSupplierID %></td>
                    <td><%= productSupplier.productID %></td>
                    <td><%= productSupplier.productName %></td>
                    <td><%= productSupplier.supplierID %></td>
                    <td><%= productSupplier.supplierName %></td>
                    <td><%= productSupplier.cost %></td>
                </tr>
            <% }); %>
        </tbody>
    </table>

    <h2>Add Product Supplier</h2>
    <form method="POST" action="/add-product-supplier">
        <p>Restriction: Do not add a duplicate Product ID-Supplier ID combo. Check table above to confirm</p>
        <label>Product:</label>
        <select name="productID">
            <% ProductSuppliers.forEach(function(productSupplier) { %>
                <option>
                    <%= productSupplier.productID %>
                    -
                    <%= productSupplier.productName %>
                </option>
            <% }); %>
        </select><br><br>

        <label>Supplier:</label>
        <select name="supplierID">
            <% ProductSuppliers.forEach(function(productSupplier) { %>
                <option>
                    <%= productSupplier.supplierID %>
                    -
                    <%= productSupplier.supplierName %>
                </option>
            <% }); %>
        </select><br><br>

        <label>Cost:</label>
        <input type="number" step="0.01" name="cost"><br><br>

        <button type="submit">Add Product Supplier</button>
    </form>

    <h2>Update Product Supplier</h2>
    <form method="post" action="update-product-supplier">

        <p>Restriction: do not select a pre-existing (Product ID, SupplierID) combo (see table above) unless it pertains to the same Product-Supplier ID. 
            E.g. you can select Product ID = 3 and Supplier ID = 2 only if you also select Product-Supplier ID of 3 </p>
        <label>Select Product-Supplier ID (check table above):</label>
        <select name="updateProductSupplierID">
            <% ProductSuppliers.forEach(function(productSupplier) { %>
                <option>
                    <%= productSupplier.productSupplierID %>
                    -
                    <%= productSupplier.productName %>
                    -
                    <%= productSupplier.supplierName %>
                </option>
            <% }); %>
        </select><br><br>

        <label>Select Product ID:</label>
        <select name="updateProductSupplier_productID">
            <% ProductSuppliers.forEach(function(productSupplier) { %>
                <option>
                    <%= productSupplier.productID %>
                    -
                    <%= productSupplier.productName %>
                </option>
            <% }); %>
        </select><br><br> 

        <label>Select Supplier ID:</label>
        <select name="updateProductSupplier_supplierID">
            <% ProductSuppliers.forEach(function(productSupplier) { %>
                <option>
                    <%= productSupplier.supplierID %>
                    -
                    <%= productSupplier.supplierName %>
                </option>
            <% }); %>
        </select><br><br>

        <label>Updated Cost:</label>
        <input type="number" step="0.01" name="updatedCost_productSupplier"><br><br>

        <button type="submit">Update Product Supplier</button>
    </form>

    <h2>Delete Product Supplier</h2>
    <form method="post" action="delete-product-supplier">
        <label>Select Relationship:</label>
        <select name="deleteProductSupplierID">
            <% ProductSuppliers.forEach(function(productSupplier) { %>
                <option>
                    <%= productSupplier.productSupplierID %>
                    -
                    <%= productSupplier.productName %>
                    -
                    <%= productSupplier.supplierName %>
                </option>
            <% }); %>
        </select><br><br>

        <button type="submit">Delete Product Supplier</button>
    </form>
</body>
</html>